<!DOCTYPE html>
<html{{#match @custom.color_scheme "Dark"}} class="theme-dark"{{/match}}{{#match @custom.color_scheme "Light"}} class="theme-light"{{/match}} lang="{{@site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title page=(t " (Page %)")}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    <style>
        :root{
            /* premium minimal palette */
            --bg: #FBFBFA; /* very light ivory */
            --card: #FFFFFF;
            --text: #0B0C0D; /* deep near-black */
            --muted: #6B7280; /* subtle slate */
            --accent: #8B5E3C; /* warm film brown accent */
            --soft-border: rgba(11,12,13,0.06);
        }

        body,
        .site,
        .site-content,
        .site-main,
        .gh-feed,
        .featured-wrapper,
        .gh-foot {
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
            -webkit-font-smoothing:antialiased;
            -moz-osx-font-smoothing:grayscale;
            line-height: 1.7;
            font-weight: 400;
        }

        /* Headings use an elegant serif for a cinematic voice */
        .gh-head-logo,
        .zen-title,
        .home-cinema-title,
        .zen-post-item h3 a {
            font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
            color: var(--text);
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        /* Minimal header */
        .gh-head {
            background: transparent !important;
            border-bottom: 1px solid var(--soft-border);
        }

        /* Hero adjustments: stronger, cinematic but minimal */
        .home-cinema-hero {
            position: relative;
            width: 100vw;
            margin: 0 calc(50% - 50vw) 54px;
            overflow: hidden;
            border-radius: 0;
            border: 0;
            background: transparent;
        }

        .home-cinema-slide {
            min-width: 100%;
            position: relative;
            aspect-ratio: 21 / 9; /* wider, cinematic crop */
            overflow: hidden;
        }

        .home-cinema-slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(78%) contrast(105%) brightness(0.98);
            transform-origin: center;
            transition: transform 12s ease;
        }

        .home-cinema-slide:hover img { transform: scale(1.03); }

        .home-cinema-overlay {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            padding: 36px 48px;
            background: linear-gradient(to top, rgba(3,3,3,0.82), rgba(3,3,3,0.08));
            color: #fff;
        }

        .home-cinema-kicker { font-size: 0.93rem; color: rgba(255,255,255,0.9); font-weight:600; }
        .home-cinema-title { margin: 0; font-size: clamp(2.2rem, 4.2vw, 4.6rem); line-height: 1.02; }

        /* Links reduced to understated text links */
        .home-cinema-links { display:flex; gap:12px; padding:12px 18px; background:transparent; border-top:0; }
        .home-cinema-link { color: rgba(255,255,255,0.92); text-decoration: none; font-weight:600; font-size:0.98rem; background:transparent; border-radius:0; border:0; }
        .home-cinema-link:hover { text-decoration:underline; }

        .home-cinema-controls .home-cinema-btn{ width:42px; height:42px; border-radius:6px; background: rgba(255,255,255,0.94); color: var(--text); font-size:1.15rem; }
        .home-cinema-dots .home-cinema-dot{ width:8px; height:8px; background: rgba(255,255,255,0.45); }

        /* Page layout and spacing */
        .zen-page { width: min(980px, calc(100% - 48px)); margin: 0 auto 72px; }
        .zen-intro, .zen-topic { padding: 36px 0; border-bottom: 1px solid var(--soft-border); }

        .zen-kicker { color: var(--muted); font-weight:700; letter-spacing:0.12em; text-transform:uppercase; }
        .zen-title { margin: 0 0 18px; font-size: clamp(2.4rem, 5vw, 4.2rem); }
        .zen-page p { margin: 0 0 16px; color: rgba(11,12,13,0.92); font-size:1.06rem; }

        /* Post list: minimal cards with generous spacing */
        .zen-post-list { display: grid; gap: 20px; margin-top: 22px; }
        .zen-post-item { background: var(--card); border: 1px solid var(--soft-border); border-radius: 6px; padding: 20px; box-shadow: none; }

        .zen-post-image-wrap { margin: -20px -20px 16px; border-radius: 6px 6px 0 0; overflow:hidden; background: #f8f8f8; aspect-ratio: 3 / 2; }
        .zen-post-image { width:100%; height:100%; object-fit:cover; filter: grayscale(28%) contrast(102%); transition: transform 8s ease; }
        .zen-post-image-wrap:hover .zen-post-image{ transform: scale(1.02); }

        .zen-post-item h3 { margin: 0 0 8px; font-size: clamp(1.4rem, 2.6vw, 1.95rem); }
        .zen-post-item h3 a { color: var(--text); text-decoration:none; font-weight:700; }

        .zen-post-meta{ font-size:0.95rem; color:var(--muted); margin-bottom:12px; display:flex; gap:8px; align-items:center; }
        .zen-hashtags a{ color:var(--accent); text-decoration:none; margin-right:10px; font-weight:600; }

        @media (max-width:900px){
            .home-cinema-overlay{ padding:18px; }
            .home-cinema-title{ font-size: clamp(1.6rem, 8.5vw, 2.8rem); }
            .zen-page{ width: calc(100% - 30px); margin-bottom:40px; }
            .zen-post-image-wrap{ aspect-ratio: 16 / 9; }
        }
    </style>

    {{ghost_head}}
</head>

<body class='{{body_class}}{{{block "body_class"}}} is-head-{{#match @custom.navigation_layout "Logo on the left"}}left-logo{{else match @custom.navigation_layout "Logo in the middle"}}middle-logo{{else}}stacked{{/match}}{{#match @custom.title_font "=" "Elegant serif"}} has-serif-title{{/match}}{{#match @custom.body_font "=" "Elegant serif"}} has-serif-body{{/match}}'>
<div class="site">

    <header id="gh-head" class="gh-head gh-outer">
        <div class="gh-head-inner gh-inner">
            <div class="gh-head-brand">
                <div class="gh-head-brand-wrapper">
                    <a class="gh-head-logo" href="{{@site.url}}">
                        {{#if @site.logo}}
                            <img src="{{@site.logo}}" alt="{{@site.title}}">
                            {{#if @custom.white_logo_for_dark_mode}}
                                <img src="{{img_url @custom.white_logo_for_dark_mode}}" alt="{{@site.title}}">
                            {{/if}}
                        {{else}}
                            {{@site.title}}
                        {{/if}}
                    </a>
                    <p class="gh-head-subtitle">{{@site.description}}</p>
                </div>
                <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                <button class="gh-burger" aria-label="{{t "Toggle menu"}}"></button>
            </div>

            <nav class="gh-head-menu">
                {{navigation}}
                {{#unless @site.members_enabled}}
                    {{#match @custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    {{/match}}
                {{/unless}}
            </nav>

            <div class="gh-head-actions">
                {{#unless @site.members_enabled}}
                    {{^match @custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    {{/match}}
                {{else}}
                    <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    <div class="gh-head-members">
                        {{#unless @member}}
                            {{#unless @site.members_invite_only}}
                                <a class="gh-head-link" href="#/portal/signin" data-portal="signin">{{t "Sign in"}}</a>
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signup" data-portal="signup">{{t "Subscribe"}}</a>
                            {{else}}
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signin" data-portal="signin">{{t "Sign in"}}</a>
                            {{/unless}}
                        {{else}}
                            <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/account" data-portal="account">{{t "Account"}}</a>
                        {{/unless}}
                    </div>
                {{/unless}}
            </div>
        </div>
    </header>

    {{#is "home"}}
        {{> "hero-cinema-carousel"}}
    {{/is}}

    <div class="site-content">
        {{#is "home"}}
            {{> "zen-single-page"}}
        {{else}}
            {{{body}}}
        {{/is}}
    </div>

    <footer class="gh-foot{{#unless @site.secondary_navigation}} no-menu{{/unless}} gh-outer">
        <div class="gh-foot-inner gh-inner">
            <div class="gh-copyright">
                {{@site.title}} © {{date format="YYYY"}}
            </div>
            {{#if @site.secondary_navigation}}
                <nav class="gh-foot-menu">
                    {{navigation type="secondary"}}
                </nav>
            {{/if}}
        </div>
    </footer>

</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script
    src="https://code.jquery.com/jquery-3.5.1.min.js"
    integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
    crossorigin="anonymous">
</script>
<script src='{{asset "built/main.min.js"}}'></script>
<script>
    (function () {
        const hero = document.querySelector(".home-cinema-hero");
        if (!hero) return;

        const track = hero.querySelector(".home-cinema-track");
        const slides = Array.from(hero.querySelectorAll(".home-cinema-slide"));
        const dotsWrap = hero.querySelector(".home-cinema-dots");
        const prevBtn = hero.querySelector(".home-cinema-btn.prev");
        const nextBtn = hero.querySelector(".home-cinema-btn.next");
        let current = 0;
        let timer;

        slides.forEach((_, idx) => {
            const dot = document.createElement("button");
            dot.className = "home-cinema-dot" + (idx === 0 ? " active" : "");
            dot.type = "button";
            dot.setAttribute("aria-label", "Go to slide " + (idx + 1));
            dot.addEventListener("click", function () {
                current = idx;
                render();
                restart();
            });
            dotsWrap.appendChild(dot);
        });

        function render() {
            track.style.transform = "translateX(-" + current * 100 + "%)";
            const dots = hero.querySelectorAll(".home-cinema-dot");
            dots.forEach((dot, idx) => dot.classList.toggle("active", idx === current));
        }

        function next() {
            current = (current + 1) % slides.length;
            render();
        }

        function prev() {
            current = (current - 1 + slides.length) % slides.length;
            render();
        }

        function restart() {
            clearInterval(timer);
            timer = setInterval(next, 4200);
        }

        nextBtn.addEventListener("click", function () { next(); restart(); });
        prevBtn.addEventListener("click", function () { prev(); restart(); });

        restart();
        render();
    })();
</script>

{{ghost_foot}}

</body>
</html>